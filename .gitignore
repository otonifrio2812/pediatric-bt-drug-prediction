# ====== 研究資料相關(重要!不可上傳)======

# 原始資料(受授權限制,使用者自行下載)
data/raw/
data/*.xlsx
data/*.tsv
data/*.csv
data/*.txt
!data/README.md

# 中繼檔(用 GitHub Release 或 Zenodo 分發)
*.parquet
*.pkl
*.joblib
intermediates/
outputs/

# 訓練好的模型(GitHub Release)
*.h5
*.bin
*.model
models/*.json

# === 但允許小型範例資料 ===
!data/example_*.csv
!data/sample_*.parquet


# ====== Python 標準 ignores ======
